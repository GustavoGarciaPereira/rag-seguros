# Copie este arquivo para .env e preencha com suas chaves reais.
# Nunca comite o arquivo .env no repositório.

# Chave de API da DeepSeek (obrigatória)
# Obtenha em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key_here

# Chave secreta para o endpoint administrativo POST /admin/upload (obrigatória)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=your_admin_secret_here

# Nível de log do servidor (opcional, padrão: INFO)
# Valores: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Habilita os endpoints POST /upload e POST /admin/upload (padrão: true)
# Em produção com índice pré-construído (faiss_db/ no git), defina false
# para evitar tentativas de upload que causam OOM no Render gratuito.
ENABLE_UPLOAD=true
