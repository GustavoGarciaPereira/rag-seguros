# Arquivo de exemplo de configuração de ambiente
# Renomeie este arquivo para .env e preencha com suas chaves

# Sua chave de API da DeepSeek
DEEPSEEK_API_KEY=sua_chave_aqui

# Chave secreta para o endpoint administrativo /admin/upload
ADMIN_API_KEY=gere_uma_chave_secreta_aqui

# Configurações opcionais do servidor
# HOST=0.0.0.0
# PORT=8000
# DEBUG=true
# LOG_LEVEL=INFO